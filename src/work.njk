---
layout: layouts/base.njk
title: "Work \u2014 Conor McArdle"
description: "Selected work by Conor McArdle \u2014 website redesigns, video production, multimedia strategy, and institutional communications."
navKey: work
bodyClass: page-work
statusPath: "~/portfolio/work.html"
permalink: /work/
---

<!-- Page Header -->
<section class="hero">
  <div class="container">
    <div class="hero__content">
      <p class="hero__label">// work</p>
      <h1 class="hero__name" style="font-size: clamp(2rem, 5vw, 3rem);">Selected Work</h1>
      <p class="hero__role">Case studies from MIT, Peddie School, and Vermont Academy.</p>
    </div>
  </div>
</section>

<!-- Projects Grid -->
<section class="section">
  <div class="container">
    <div class="cards-grid">
      {% for item in collections.work %}
      <article class="card" data-animate{% if loop.index is odd %} data-animate-delay="1"{% endif %}>
        <a href="{{ item.url }}" class="card__link">
          <div class="card__image">
            {% if item.data.cardImage %}
            <img src="{{ item.data.cardImage }}" alt="{{ item.data.cardImageAlt }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;">
            {% else %}
            <div class="card__image-placeholder">{{ item.data.cardPlaceholder }}</div>
            {% endif %}
          </div>
          <div class="card__body">
            <span class="card__number">{{ item.data.displayOrder | padStart(2) }}</span>
            <h3 class="card__title">{{ item.data.cardTitle }}</h3>
            <p class="card__desc">{{ item.data.cardDesc }}</p>
            <div class="card__meta">
              <span class="card__meta-item"><span class="card__meta-key">role:</span> {{ item.data.cardRole }}</span>
              <span class="card__meta-item"><span class="card__meta-key">timeline:</span> {{ item.data.cardTimeline }}</span>
            </div>
          </div>
        </a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
